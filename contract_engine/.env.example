# Copy this file to .env and replace placeholder values before running.
# The application loads these values automatically via python-dotenv.

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
NHTSA_API_URL=https://vpic.nhtsa.dot.gov/api/vehicles/DecodeVinValuesExtended/
# Cloud MongoDB example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/contract_engine?retryWrites=true&w=majority
# Optional explicit database name if the URI does not include one:
# MONGODB_DB_NAME=contract_engine
MONGODB_URI=
OPENROUTER_MODEL=openai/gpt-4o-mini
